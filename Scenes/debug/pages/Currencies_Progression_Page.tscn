[gd_scene format=3]

[ext_resource type="Script" path="res://Scripts/Debug/pages/currencies_progression_page.gd" id="1_script"]

[node name="CurrenciesProgressionPage" type="Control" node_paths=PackedStringArray("_silver_spin", "_supplies_spin", "_fortunes_favor_spin", "_encounter_id_edit", "_difficulty_spin", "_encounters_label")]
layout_mode = 2
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")
_silver_spin = NodePath("MarginContainer/VBoxContainer/CurrenciesGrid/SpinBox_Silver")
_supplies_spin = NodePath("MarginContainer/VBoxContainer/CurrenciesGrid/SpinBox_Supplies")
_fortunes_favor_spin = NodePath("MarginContainer/VBoxContainer/CurrenciesGrid/SpinBox_FortunesFavor")
_encounter_id_edit = NodePath("MarginContainer/VBoxContainer/ProgressionRow/LineEdit_EncounterID")
_difficulty_spin = NodePath("MarginContainer/VBoxContainer/ProgressionRow/SpinBox_Difficulty")
_encounters_label = NodePath("MarginContainer/VBoxContainer/Label_Encounters")

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 2
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 16

